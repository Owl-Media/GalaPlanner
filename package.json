{
  "name": "gala-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev -w @gala-planner/backend\" \"npm run dev -w @gala-planner/frontend\"",
    "build": "npm run build -ws",
    "test": "npm run test -ws --if-present",
    "lint": "eslint packages --ext .ts,.tsx",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,css}\""
  },
  "overrides": {
    "rollup": "^4.60.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "prettier": "^3.8.3",
    "rollup": "^4.60.1",
    "typescript": "^6.0.2",
    "vite": "^8.1.4"
  }
}
